NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption key for user credentials (generate with: openssl rand -base64 32)
# Must match the key set in Supabase edge function secrets and Vercel env vars
CREDENTIAL_ENCRYPTION_KEY=your-base64-encryption-key
